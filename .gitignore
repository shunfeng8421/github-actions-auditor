# Runtime outputs (except tracking files)
auditor/logs/
auditor/findings/
auditor/case-studies/

# Python
__pycache__/
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db

# Keep directory structure
!auditor/logs/.gitkeep
!auditor/findings/.gitkeep
!auditor/case-studies/.gitkeep

# Allow specific tracking files through
!auditor/logs/discovered_repos.jsonl
!auditor/logs/discover_state.json
!auditor/logs/events.jsonl
!auditor/logs/pr_tracking.jsonl
!auditor/logs/pr_status.jsonl
!auditor/logs/summary.json
!auditor/logs/audit_report.md
!auditor/logs/daily_report_*.md
!auditor/findings/*/findings.jsonl
!auditor/findings/*/findings_summary.json
!auditor/findings/findings.jsonl
!auditor/findings/findings_summary.json